{
  "name": "mdproof Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "mdproof-devcontainer",
  "workspaceFolder": "/workspace",
  "remoteEnv": {
    "PATH": "/workspace/bin:${containerEnv:PATH}",
    "MDPROOF_ALLOW_EXECUTE": "1"
  },
  "postCreateCommand": ".devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ]
    }
  }
}
