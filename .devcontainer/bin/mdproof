#!/usr/bin/env bash
# Dev wrapper: compile from source then exec the binary directly.
# Unlike `go run`, this preserves exact exit codes and avoids
# the extra "exit status N" line that go run prints to stderr.
set -euo pipefail

TMP_BIN="/tmp/mdproof-dev"

if ! (cd /workspace && go build -o "$TMP_BIN" ./cmd/mdproof); then
  echo "mdproof: build failed" >&2
  exit 1
fi

exec "$TMP_BIN" "$@"
